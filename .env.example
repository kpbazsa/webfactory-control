# Supabase project URL (safe to commit / expose).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase ANON key only — NEVER the service-role key.
# This app is browser-shipped: the anon key is exposed to clients by design.
# RLS protects the PWA-facing tables. If you ever need elevated access,
# do it from a separate trusted backend, not this app.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
